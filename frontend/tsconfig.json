{
  "compilerOptions": {
    "target": "ES2022", /* 🎯 OPTIMIZATION: Updated from ES2017 to match your modern React 19 / Next.js 16 stack */
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    
    /* 🎯 THE FIX: Switch from "node" to "bundler" to eliminate the deprecation warning */
    "moduleResolution": "bundler", 
    "allowImportingTsExtensions": true, /* Resolves modern bundler file extension rules */
    
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}